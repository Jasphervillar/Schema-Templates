<script type="application/ld+json">
{
  "_INSTRUCTIONS": {
    "purpose": "Service category page schema markup template for dental practices — use this for category landing pages like General Dentistry, Cosmetic Dentistry, Family Dentistry, Restorative Dentistry, etc.",
    "rules": [
      "USE this template for service category pages — pages with slugs like /general-dentistry, /cosmetic-dentistry, /restorative-dentistry, /family-dentistry",
      "DO NOT use this template for individual service pages like /teeth-whitening or /veneers — use Individual Service Page template for those",
      "DO NOT use this template for the main services listing page — use Services Main Page template for that",
      "SCAN the entire category page fully before filling anything",
      "REMOVE any field that has no data available — never leave a placeholder empty",
      "NEVER guess or fabricate any information — only use what is found on the site",
      "@type: always use MedicalWebPage for all dental service category pages",
      "name: use the exact meta title of the category page — check page source or SEO settings",
      "description: use the exact meta description of the category page — check page source or SEO settings",
      "url: use the exact category page URL — no trailing slash unless the site uses one consistently",
      "@id: always append #webpage to the category page URL",
      "telephone: get the exact phone number from the page or site header or footer",
      "about.@id: always point back to the homepage dentist entity by appending /#dentist to the homepage URL",
      "breadcrumb: always has 2 items for category pages — position 1 is Home, position 2 is the category page name and URL",
      "breadcrumb name: use the exact category name as shown in the navigation menu — e.g. General Dentistry, Cosmetic Dentistry",
      "mainEntityOfPage: always use the same value as the url field",
      "inLanguage: always set to en unless the site is in another language",
      "NO FAQs field on this template — this template does not include mainEntity or FAQ fields",
      "NO PLACEHOLDERS: the final output must have zero placeholders — every field must contain real data or be removed entirely",
      "VALIDATE: check that all URLs are real and working, phone number matches the site, and breadcrumb name matches the navigation"
    ]
  },

  "@context": "https://schema.org",
  "@type": "MedicalWebPage",
  "@id": "{{CATEGORY_PAGE_URL}}#webpage",
  "name": "{{CATEGORY_PAGE_META_TITLE}}",
  "description": "{{CATEGORY_PAGE_META_DESCRIPTION}}",
  "url": "{{CATEGORY_PAGE_URL}}",
  "mainEntityOfPage": "{{CATEGORY_PAGE_URL}}",
  "telephone": "{{PHONE_NUMBER}}",
  "inLanguage": "en",
  "about": {
    "@id": "{{HOMEPAGE_URL}}/#dentist"
  },
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "{{HOMEPAGE_URL}}/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "{{CATEGORY_PAGE_NAV_NAME}}",
        "item": "{{CATEGORY_PAGE_URL}}"
      }
    ]
  }
}
</script>
