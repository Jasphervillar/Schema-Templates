<script type="application/ld+json">
{
  "_INSTRUCTIONS": {
    "purpose": "Home page schema for a dental practice website",
    "rules": [
      "ALWAYS use minified single-line JSON when pushing to Webflow — no indentation, no line breaks, no whitespace between fields",
      "The _INSTRUCTIONS block is for AI guidance only — NEVER include it in the pushed sourceCode",
      "NEVER pretty-print — minified JSON is mandatory to stay under Webflow's 2000 character limit",
      "@type must always be Dentist",
      "name: use the exact practice name found on the site",
      "url: use the exact homepage URL",
      "logo: use the actual logo image CDN URL found in the site header",
      "telephone: use the exact phone number found on the site, formatted as +1XXXXXXXXXX",
      "email: use the contact email found on the site",
      "address: use the exact street address, city, state, zip found on the site",
      "geo: use the actual GPS coordinates matching the address on Google Maps",
      "openingHoursSpecification: include ALL days and hours found on the site — never skip any",
      "aggregateRating: use the actual rating value and review count found on the site",
      "hasOfferCatalog: include ALL services listed on the site — never cut the list short",
      "NO PLACEHOLDERS: every field must contain real data or be removed — zero placeholders in final output"
    ]
  },
  "@context": "https://schema.org",
  "@type": "Dentist",
  "@id": "{{HOMEPAGE_URL}}/#dentist",
  "name": "{{PRACTICE_NAME}}",
  "url": "{{HOMEPAGE_URL}}",
  "logo": "{{LOGO_CDN_URL}}",
  "telephone": "{{PHONE_E164}}",
  "email": "{{EMAIL}}",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "{{STREET}}",
    "addressLocality": "{{CITY}}",
    "addressRegion": "{{STATE}}",
    "postalCode": "{{ZIP}}",
    "addressCountry": "US"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "{{LAT}}",
    "longitude": "{{LNG}}"
  },
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["{{DAY_1}}"],
      "opens": "{{OPEN_TIME}}",
      "closes": "{{CLOSE_TIME}}"
    }
  ],
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "{{RATING}}",
    "reviewCount": "{{REVIEW_COUNT}}",
    "bestRating": "5"
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Dental Services",
    "itemListElement": [
      {"@type": "Offer","itemOffered": {"@type": "Service","name": "{{SERVICE_1}}"}},
      {"@type": "Offer","itemOffered": {"@type": "Service","name": "{{SERVICE_2}}"}}
    ]
  }
}
</script>
