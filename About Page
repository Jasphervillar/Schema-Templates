<script type="application/ld+json">
{
  "_INSTRUCTIONS": {
    "purpose": "About page schema markup template for dental practices",
    "rules": [
      "SCAN the about page fully before filling anything",
      "REMOVE any field that has no data available — never leave a placeholder empty",
      "NEVER guess or fabricate any information — only use what is found on the site",
      "name: use the exact meta title of the about page — check page source or SEO settings",
      "description: use the exact meta description of the about page — check page source or SEO settings",
      "url: use the exact about page URL — no trailing slash unless the site uses one consistently",
      "@id: always append #webpage to the about page URL",
      "about.@id: always point back to the homepage dentist entity by appending /#dentist to the homepage URL — this links the about page to the main business entity",
      "breadcrumb: always has 2 items — position 1 is always Home with the homepage URL, position 2 is the about page name and URL",
      "breadcrumb name: use the exact page name as it appears in the navigation menu of the site — check if it says About, About Us, Our Team, Meet the Doctors, etc.",
      "mainEntityOfPage: always use the same value as the url field",
      "inLanguage: always set to en unless the site is in another language",
      "NO PLACEHOLDERS: the final output must have zero placeholders — every field must contain real data or be removed entirely",
      "VALIDATE: check that all URLs are real and working, page title matches the actual about page meta title, and the homepage @id URL is correct"
    ]
  },

  "@context": "https://schema.org",
  "@type": "AboutPage",
  "@id": "{{ABOUT_PAGE_URL}}#webpage",
  "name": "{{ABOUT_PAGE_META_TITLE}}",
  "description": "{{ABOUT_PAGE_META_DESCRIPTION}}",
  "url": "{{ABOUT_PAGE_URL}}",
  "mainEntityOfPage": "{{ABOUT_PAGE_URL}}",
  "inLanguage": "en",
  "about": {
    "@id": "{{HOMEPAGE_URL}}/#dentist"
  },
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "{{HOMEPAGE_URL}}/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "{{ABOUT_PAGE_NAV_NAME}}",
        "item": "{{ABOUT_PAGE_URL}}"
      }
    ]
  }
}
</script>
